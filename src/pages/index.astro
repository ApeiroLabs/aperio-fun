---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleRow from "../components/ArticleRow.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft && data.lang === "zh"))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout>
  <section class="hero hero-compact">
    <p class="hero-kicker reveal">A personal field journal · 个人博客</p>
    <h1 class="hero-title hero-title-short">
      <span class="reveal">保持</span>
      <span class="hero-indent reveal">好奇。</span>
    </h1>
    <div class="hero-note reveal">
      <span class="note-number">01</span>
      <p>这里收集技术、创造与日常生活里，那些值得多看一眼的东西。</p>
    </div>
    <div class="hero-mark" aria-hidden="true">A</div>
  </section>

  {posts.length > 0 && (
    <section class="latest" aria-labelledby="latest-title">
      <div class="section-heading">
        <p class="eyebrow">Latest writing</p>
        <h2 id="latest-title">最近写下的</h2>
        <span>{String(posts.length).padStart(2, "0")}</span>
      </div>
      <div class="article-list">
        {posts.slice(0, 5).map((post, index) => <ArticleRow post={post} index={index} />)}
      </div>
      <a class="text-link" href="/writing/">查看所有文章 <span>→</span></a>
    </section>
  )}

  <aside class="home-note">
    <p class="eyebrow">About this place</p>
    <blockquote>“Aperio” 意为打开、揭示。写作或许就是把模糊的感受打开一点，让它见光。</blockquote>
    <a class="text-link" href="/about/">关于我和这个网站 <span>→</span></a>
  </aside>
</BaseLayout>
