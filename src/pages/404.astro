---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="页面没有找到 — Aperio">
  <section class="not-found">
    <p class="error-code">404</p>
    <div>
      <p class="eyebrow">This page stayed unwritten</p>
      <h1>这一页还没有被写下。</h1>
      <p>也可能它搬去了别处。先回到首页，那里有一些已经成形的文字。</p>
      <a class="text-link" href="/">回到首页 <span>→</span></a>
    </div>
  </section>
</BaseLayout>
