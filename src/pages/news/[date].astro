---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatIssueDate, parseDailyIssue } from "../../lib/content";

export async function getStaticPaths() {
  const entries = await getCollection("dailyNews");
  return entries
    .map(parseDailyIssue)
    .filter((issue) => issue.lang === "zh")
    .map((issue) => ({
      params: { date: issue.date },
      props: { issue }
    }));
}

const { issue } = Astro.props;
const { Content } = await render(issue.entry);
const title = `每日速递 · ${formatIssueDate(issue.date, "zh")}`;
---

<BaseLayout
  title={`${title} — Aperio`}
  description="由 Horizon 筛选和整理的每日科技资讯。"
  locale="zh"
  switchHref={`/en/news/${issue.date}/`}
>
  <article class="report">
    <header class="report-header">
      <a class="back-link" href="/news/">← 返回每日速递</a>
      <p class="eyebrow">Horizon · {issue.date}</p>
      <h1>每日速递</h1>
      <div class="report-meta">
        <time datetime={issue.date}>{formatIssueDate(issue.date, "zh")}</time>
        <span>中文</span>
      </div>
    </header>
    <div class="prose generated-report">
      <Content />
    </div>
  </article>
</BaseLayout>
