---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout locale="en" switchHref="/about/" title="About — Aperio" description="About Aperio and the person behind it.">
  <div class="about-grid">
    <header class="page-header about-header">
      <p class="eyebrow">About</p>
      <h1>Hello,<br />this is Aperio.</h1>
    </header>
    <div class="about-copy prose prose-en">
      <p class="lead">This is my personal blog, and a place where conclusions do not have to arrive too early.</p>
      <p>I write about technology, products, creativity, and the details that surface in everyday life. Rather than offering standard answers, I want to open a question and look at its actual texture.</p>
      <p>The name comes from the Latin <em>aperio</em>: to open, reveal, or bring into view. That is also my simplest hope for writing.</p>
      <h2>Keep in touch</h2>
      <p>If something here gives you a thought, write to <a href="mailto:hello@aperio.fun">hello@aperio.fun</a>.</p>
    </div>
  </div>
</BaseLayout>
