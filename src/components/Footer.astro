---
import { localeMeta, type Locale } from "../config/i18n";

interface Props {
  locale?: Locale;
}

const { locale = "zh" } = Astro.props;
const copy = locale === "zh"
  ? { mail: "来信" }
  : { mail: "Email" };
---

<footer class="site-footer">
  <div>
    <span>© {new Date().getFullYear()} Aperio</span>
    <a href={localeMeta[locale].rss}>RSS</a>
    <a href="mailto:hello@aperio.fun">{copy.mail}</a>
  </div>
</footer>
