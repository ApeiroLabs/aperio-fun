---
import { localizedPath, localeMeta, type Locale } from "../config/i18n";

interface Props {
  locale?: Locale;
  switchHref?: string;
}

const { locale = "zh", switchHref = locale === "zh" ? "/en/" : "/" } = Astro.props;
const path = Astro.url.pathname;
const labels = locale === "zh"
  ? { writing: "文章", news: "速递", inspiration: "灵感", about: "关于", home: "Aperio 首页", skip: "跳到正文" }
  : { writing: "Writing", news: "Daily", inspiration: "Ideas", about: "About", home: "Aperio home", skip: "Skip to content" };
const links = [
  { href: localizedPath(locale, "/writing/"), label: labels.writing },
  { href: localizedPath(locale, "/news/"), label: labels.news },
  { href: localizedPath(locale, "/inspiration/"), label: labels.inspiration },
  { href: localizedPath(locale, "/about/"), label: labels.about }
];
const activePath = locale === "en" ? path.replace(/^\/en/, "") : path;
---

<a class="skip-link" href="#main-content">{labels.skip}</a>
<header class="site-header">
  <a class="wordmark" href={localizedPath(locale)} aria-label={labels.home}>
    <span>aperio</span><i>.</i>fun
  </a>
  <nav aria-label="主导航">
    {links.map((link) => (
      <a href={link.href} aria-current={activePath.startsWith(link.href.replace(/^\/en/, "")) ? "page" : undefined}>
        {link.label}
      </a>
    ))}
    <a class="locale-switch" href={switchHref} hreflang={locale === "zh" ? "en" : "zh-CN"}>
      {localeMeta[locale === "zh" ? "en" : "zh"].shortLabel}
    </a>
  </nav>
</header>
