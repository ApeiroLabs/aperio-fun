---
import BaseLayout from "./BaseLayout.astro";
import { localizedPath, type Locale } from "../config/i18n";

const { title, description, publishedAt, tags = [], locale = "zh", switchHref } = Astro.props;
const date = publishedAt.toLocaleDateString(locale === "zh" ? "zh-CN" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric"
});
---

<BaseLayout title={`${title} — Aperio`} description={description} locale={locale as Locale} switchHref={switchHref}>
  <article class="post">
    <header class="post-header">
      <a class="back-link" href={localizedPath(locale, "/writing/")}>{locale === "zh" ? "← 返回所有文章" : "← All writing"}</a>
      <p class="eyebrow">{locale === "zh" ? "A note from Aperio" : "Writing · Aperio"}</p>
      <h1>{title}</h1>
      <p class="post-deck">{description}</p>
      <div class="post-meta">
        <time datetime={publishedAt.toISOString()}>{date}</time>
        {tags.length > 0 && <span>{tags.join(" · ")}</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="post-end">
      <span aria-hidden="true">※</span>
      <p>{locale === "zh" ? "感谢你读到这里。" : "Thank you for reading."}</p>
      <a href={localizedPath(locale, "/writing/")}>{locale === "zh" ? "继续读别的文章 →" : "Read more →"}</a>
    </footer>
  </article>
</BaseLayout>
